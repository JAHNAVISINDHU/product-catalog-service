{
  "name": "product-catalog-service",
  "version": "1.0.0",
  "description": "E-commerce Product Catalog Microservice with Repository Pattern",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
